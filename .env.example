# StudyKit Environment Configuration
# Copy this file to .env and update values for your environment

# Database
DATABASE_URL=postgres://postgres:postgres@db:5432/studykit_development

# Redis
REDIS_URL=redis://redis:6379

# JWT Configuration
JWT_SECRET=change_me_with_min_32_chars_secret_key
JWT_ISSUER=studykit-api
JWT_AUDIENCE=studykit-frontend

# API Configuration
API_PORT=3100
CORS_ORIGINS=http://localhost:5173,http://localhost:3001
TRUST_PROXY=false

# Token TTL
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30

# Directus Configuration
DIRECTUS_KEY=change_this_directus_key_32_chars_min
DIRECTUS_SECRET=change_this_directus_secret_32_chars_min
DIRECTUS_ADMIN_EMAIL=admin@studykit.dev
DIRECTUS_ADMIN_PASSWORD=change_me_please
